BOT_TOKEN=your_bot_token_from_botfather
CHANNEL_CHAT_ID=
# Production on cPanel: set your public app URL (enables webhook mode)
WEBHOOK_URL=https://resultbotapi.entrancetricks.com
WEBHOOK_SECRET=

# On cPanel (same server as MySQL) use localhost — not the public IP
# URL-encode special chars in password: { -> %7B  } -> %7D  & -> %26
DATABASE_URL=mysql://user:password@localhost:3306/your_database

JWT_SECRET=change-this-to-a-long-random-string

# Do NOT set PORT on cPanel — the host assigns it automatically
NODE_ENV=production

# Only when admin is on a separate subdomain (no trailing slash)
# ADMIN_ORIGIN=https://your-admin-subdomain.entrancetricks.com
